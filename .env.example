# Copie este arquivo para .env e preencha os valores
# NUNCA versione o arquivo .env

# Banco de dados (desenvolvimento local com Docker)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/finance
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Chave AES-256 para criptografar numero_conta e agencia (32 bytes em Base64)
# Gere com: openssl rand -base64 32
ENCRYPTION_KEY=

# Google OAuth (Web Client ID do Google Cloud Console)
GOOGLE_CLIENT_ID=

# GCP (apenas para deploy em produção)
GCP_PROJECT_ID=
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
